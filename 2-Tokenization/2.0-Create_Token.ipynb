   "source": [
    "import tiktoken\n",
    "\n",
    "enc  = tiktoken.encoding_for_model(\"gpt-4o\")\n",
    "text = \"Hey there! My name is Roshan\"\n",
    "token = enc.encode(text)\n",
    "detoken = enc.decode(token)\n",
    "\n",
    "print(\"Text : \", text)\n",
    "print(\"Tokens : \", token)\n",
    "print(\"Detoken : \", detoken)\n",
    "print(\"Number of tokens : \", len(token))"
   ]
  }
 ],
